{
  "name": "crossflow-protocol",
  "version": "1.0.0",
  "description": "Cross-chain DeFi ecosystem built on LayerOneX",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "sdk"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "contracts:build": "cd contracts && cargo build --release",
    "contracts:test": "cd contracts && cargo test",
    "contracts:deploy": "cd contracts && l1x-cli deploy",
    "test": "npm run test:frontend && npm run test:backend && npm run contracts:test",
    "test:frontend": "cd frontend && npm run test",
    "test:backend": "cd backend && npm run test",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
